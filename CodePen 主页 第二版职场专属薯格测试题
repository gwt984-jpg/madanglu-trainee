// ===== 状态管理 =====
let currentQuestions = [];
let currentIndex = 0;
let answers = []; 
let currentMode = '';
let autoNextTimer = null; 
let currentPersona = null; // 确保唯一的变量名

// ===== 流程逻辑 =====
function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById('screen-' + id).classList.add('active');
  if(id === 'mode') {
    document.getElementById('header-box').style.display = 'block';
  } else {
    document.getElementById('header-box').style.display = 'none';
  }
}

function showModal(id) { document.getElementById(id).classList.add('show'); }
function hideModal(id) { document.getElementById(id).classList.remove('show'); }

function startQuiz(mode) {
  currentMode = mode;
  currentQuestions = mode === 'light' ? questionsData : [...questionsData, ...deepExtra];
  currentIndex = 0;
  answers = new Array(currentQuestions.length).fill(-1);
  renderQ();
  showScreen('quiz');
}

function renderQ() {
  const q = currentQuestions[currentIndex];
  document.getElementById('progress-bar').style.width = ((currentIndex / currentQuestions.length) * 100) + '%';
  document.getElementById('q-num').textContent = `第 ${currentIndex+1}/${currentQuestions.length} 题`;
  document.getElementById('q-type').textContent = q.type;
  document.getElementById('question-text').textContent = q.q;

  const wrap = document.getElementById('options-wrap');
  wrap.innerHTML = q.opts.map((o,i) => `
    <button class="option-btn ${answers[currentIndex]===i?'selected':''}" onclick="selectOpt(${i})">
      <span class="opt-letter">${['A','B','C','D'][i]}</span>
      <span>${o}</span>
    </button>
  `).join('');

  document.querySelector('.btn-back').style.visibility = currentIndex === 0 ? 'hidden' : 'visible';
  document.getElementById('btn-next').disabled = answers[currentIndex] === -1;
  document.getElementById('btn-next').textContent = currentIndex === currentQuestions.length - 1 ? '一键生成报告 ✨' : '下一题 →';
}

function selectOpt(i) {
  if (autoNextTimer) clearTimeout(autoNextTimer);
  
  answers[currentIndex] = i;
  
  document.querySelectorAll('.option-btn').forEach((btn, idx) => {
    btn.classList.toggle('selected', idx === i);
  });
  document.getElementById('btn-next').disabled = false;

  autoNextTimer = setTimeout(nextQ, 300);
}

function nextQ() {
  if (autoNextTimer) clearTimeout(autoNextTimer);
  if (answers[currentIndex] === -1) return;
  
  if (currentIndex < currentQuestions.length - 1) { 
    currentIndex++; 
    renderQ(); 
  } else { 
    calcResult(); 
  }
}

function prevQ() { 
  if (autoNextTimer) clearTimeout(autoNextTimer);
  if (currentIndex > 0) { 
    currentIndex--; 
    renderQ(); 
  } 
}

function calcResult() {
  showScreen('loading');
  
  const scores = [0, 0, 0, 0];
  answers.forEach(val => { if(val !== -1) scores[val]++; });
  
  let maxScore = Math.max(...scores);
  let winIndex = scores.indexOf(maxScore);
  
  currentPersona = personas[winIndex];

  setTimeout(() => { 
    renderResult(currentPersona); 
  }, 2000);
}

function renderResult(p) {
  document.getElementById('result-icon').textContent = p.icon;
  document.getElementById('result-name').textContent = p.name;
  document.getElementById('result-tag').textContent = p.tag;
  document.getElementById('result-desc').textContent = p.desc;

  document.getElementById('score-row').innerHTML = p.scores.map(s =>
    `<div class="score-chip"><div class="s-val">${s.n}</div><div class="s-label">${s.v}</div></div>`
  ).join('');

  document.getElementById('result-cards').innerHTML = `
    <div class="result-card"><h4>💪 核心优势</h4><ul>${p.strengths.map(s=>`<li>✧ ${s}</li>`).join('')}</ul></div>
    <div class="result-card"><h4>🎯 马当路推荐岗位</h4><ul>${p.tracks.map(t=>`<li>✧ ${t}</li>`).join('')}</ul></div>
  `;

  if (currentMode === 'deep') {
    document.getElementById('deep-extras').innerHTML = `
      <div class="deep-section">
        <h4>📈 能力雷达详解</h4>
        ${p.scores.map(s => `
          <div class="bar-item">
            <div class="bar-label"><span>${s.v}</span><span>${s.n}/100</span></div>
            <div class="bar-track"><div class="bar-fill" data-width="${s.n}%"></div></div>
          </div>
        `).join('')}
      </div>
      <div class="deep-section">
        <h4>🤖 AI工具箱清单</h4>
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px;">
          <div class="advice-chip" style="margin-bottom:0;"><strong>主攻利器</strong>${p.aiTools[0]}</div>
          <div class="advice-chip" style="margin-bottom:0;"><strong>协同提效</strong>${p.aiTools[1]}</div>
        </div>
      </div>
      <div class="deep-section">
        <h4>💡 校招成长与备考建议</h4>
        <div class="advice-chip" style="background:#fff; border:1px dashed var(--red-mid); margin-bottom:0;">${p.advice}</div>
      </div>
    `;
    
    setTimeout(() => {
      document.querySelectorAll('.bar-fill').forEach(bar => {
        bar.style.width = bar.getAttribute('data-width');
      });
    }, 150);

  } else {
    document.getElementById('deep-extras').innerHTML = `
      <div class="deep-section" style="text-align:center; padding:24px;">
        <h4 style="margin-bottom:8px;">🚀 解锁详细的【岗位备考建议+能力雷达】？</h4>
        <p style="font-size:12px; color:var(--gray); margin-bottom:14px;">深度测试将全方位解析你的AI工具匹配链条</p>
        <button class="btn-next" style="margin:0 auto; display:block;" onclick="startQuiz('deep')">参加职场深度版测评</button>
      </div>
    `;
  }
  
  showScreen('result');
  setTimeout(() => showModal('auth-modal'), 1200);
}

// ===== 修正后的弹窗跳转及重测交互 =====
function agreeAuth() {
  hideModal('auth-modal');
  showScreen('success');
}

function refuseAuth() {
  hideModal('auth-modal');
  showScreen('shared');
}

function shareResult() {
  // 修正变量名为全局可控的 currentPersona
  if (navigator.share && currentPersona) {
    navigator.share({
      title: `我是小红书「${currentPersona.name}」| 马当路练习生测评`,
      text: `${currentPersona.desc}\n快来解锁你的专属职场薯格！#我的AI职场初体验`,
      url: window.location.href
    }).catch(() => {
      alert('📋 链接已复制！快去小红书带话题 #我的AI职场初体验 晒出你的薯格吧！');
    });
  } else {
    alert('📋 截图保存海报成功！\n快去小红书带话题 #我的AI职场初体验 分享你的专属人设吧！');
  }
}

function restart() {
  currentIndex = 0;
  answers = [];
  currentPersona = null;
  if (autoNextTimer) clearTimeout(autoNextTimer);
  showScreen('mode');
}
</script>
